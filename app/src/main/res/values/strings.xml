    <!-- Warning (Phase 8) -->
    <string name="warning_title">請從防詐器進入</string>
    <string name="warning_body">為了避免您轉帳到錯誤的帳戶，請回到防詐器並從防詐器內進入此 App。</string>
    <string name="warning_confirm">我知道了</string>
    <string name="warning_blocked_label_format">被攔截：%1$s</string>

    <!-- Accessibility service (Phase 7) -->
    <string name="accessibility_service_label">防詐器保護服務</string>
    <string name="accessibility_service_description">當您嘗試打開已綁定的 App（例如網銀）卻不是從防詐器進入時，防詐器會跳出警告並把您帶回防詐器確認。此服務不會收集您的任何個人資料。</string>

    <!-- Foreground service + Device Admin (PRD §8) -->
    <string name="foreground_service_title">防詐器保護中</string>
    <string name="foreground_service_text">背景監測中，正在守護您的轉帳安全</string>
    <string name="device_admin_label">防詐器裝置守護</string>
    <string name="device_admin_description">啟用後可避免防詐器被誤刪除，提高保護完整性。可隨時於系統設定中關閉。</string>
    <string name="device_admin_disable_warning">關閉裝置管理員將解除防詐器的防誤刪保護。建議保持開啟以確保功能完整。</string>

    <!-- Main-function tab inline gate (requirement #3, revised) -->
    <string name="gate_inline_title">啟用防詐器保護</string>
    <string name="gate_inline_subtitle">以下四項全部啟用後，才能使用防詐器轉帳保護功能</string>
    <string name="gate_item_a11y">無障礙服務</string>
    <string name="gate_item_a11y_desc">攔截綁定 App 的直接開啟並提醒</string>
    <string name="gate_item_admin">裝置管理員</string>
    <string name="gate_item_admin_desc">防止防詐器被誤刪除</string>
    <string name="gate_item_notify">通知權限</string>
    <string name="gate_item_notify_desc">顯示「防詐器保護中」常駐通知</string>
    <string name="gate_item_battery">電池白名單</string>
    <string name="gate_item_battery_desc">允許防詐器背景持續執行，不被省電強制關閉</string>
    <string name="gate_battery_hint">點下後系統會彈出對話框詢問是否允許「不受電池優化」，請選「允許」</string>
    <string name="gate_action_enable">前往啟用</string>
    <string name="gate_status_on">已啟用</string>
    <string name="gate_all_ready_hint">四項全部啟用後，畫面會自動切換為防詐器主功能</string>
    <string name="gate_admin_fallback_hint">此版本系統未提供「啟用裝置管理員」直接入口，請手動點選：設定 → 安全 → 裝置管理員應用程式 → 開啟「防詐器」</string>
    <string name="gate_accessibility_open_hint">若沒看到「防詐器」開關，請在清單中向下捲動找「防詐器保護服務」</string>
    <string name="gate_launch_failed">無法開啟系統設定（%1$s），請手動到 設定 App 內開啟</string>

    <!-- Voice recognition: jump to dialer call-recording settings -->
    <string name="voice_open_call_recording_settings">前往通話錄音設定</string>
    <string name="voice_open_call_recording_hint">已開啟通話設定，請在頁面內找「通話錄音」並開啟「全部通話自動錄音」</string>
    <string name="voice_open_call_recording_fallback_hint">系統未直接提供入口，已開啟電話/設定 App，請依下方各品牌路徑手動進入</string>

    <!-- Voice recognition: auto-detect call end + scan OEM recording -->
    <string name="voice_autodetect_title">通話結束自動辨識</string>
    <string name="voice_autodetect_body">啟用後，當您結束通話、且手機本身有開啟「通話自動錄音」時，防詐器會自動偵測剛產生的錄音檔，跳通知讓您一鍵送進辨識。\n\n需要：「電話狀態」+「音檔讀取」權限。權限只用於偵測通話結束時間並讀取錄音檔，全程離線、不會上傳。</string>
    <string name="voice_autodetect_enable">啟用通話結束自動偵測</string>
    <string name="voice_autodetect_enabled">已啟用，掛斷後若有錄音檔會自動通知</string>
    <string name="voice_autodetect_denied_hint">缺少必要權限，請至 設定 → 應用程式 → 防詐器 → 權限 中開啟「電話」與「音樂與音訊」</string>

    <!-- Notification when an OEM call recording is found after call ends -->
    <string name="notif_channel_call_recording">通話錄音偵測</string>
    <string name="notif_call_recording_title">偵測到剛才的通話錄音</string>
    <string name="notif_call_recording_text">點擊即可送進防詐器語音辨識，比對是否為詐騙</string>

    <!-- Temp-use stage 1 (green pass-through, PRD § 3.3) -->
    <string name="temp_use_stage1_title">提醒</string>
    <string name="temp_use_stage1_body">這筆帳號目前屬於「臨時用」狀態（新增未滿 24 小時或選擇了預設臨時用）。\n請確認您信任這次轉帳對象，並再次核對對方帳號是否正確。</string>
    <string name="temp_use_stage1_cta">我已確認，繼續</string>

    <!-- Temp-use stage 2 (yellow forced calm + 3-checkbox) -->
    <string name="temp_use_stage2_title">第 2 次臨時轉帳警告</string>
    <string name="temp_use_stage2_body">10 分鐘內第 2 次臨時轉帳。\n165 統計：被害人平均損失 78 萬。\n您可能正在被詐騙。</string>
    <string name="temp_use_stage2_check1">政府/銀行不會要求你匯款給對方</string>
    <string name="temp_use_stage2_check2">政府/銀行不會要求你操作ATM</string>
    <string name="temp_use_stage2_check3">與其事後檢討，不如下方撥打 165</string>
    <string name="temp_use_stage2_cta">確認，繼續轉帳</string>
    <string name="temp_use_stage2_call_165">立即撥打 165</string>
    <string name="temp_use_stage2_countdown">剩餘 %1$d 秒</string>

    <!-- Temp-use stage 3 (red lockdown + auto-dial 165) -->
    <string name="temp_use_stage3_title">⚠️ 您正在被詐騙</string>
    <string name="temp_use_stage3_body">10 分鐘內第 3 次臨時轉帳。\n這是詐騙集團「逼迫快速轉帳」的標準手法。\n您正在被詐騙。</string>
    <string name="temp_use_stage3_call_cta">立即撥打 165</string>
    <string name="temp_use_stage3_locked_note">本次轉帳已被防詐器封鎖。\n剩餘冷卻時間：%1$s</string>
    <string name="temp_use_calm_mantra">錢掉進水裡還有響聲，掉進詐騙口袋連灰都不剩下，別讓你的餘生，只剩下「後悔」兩個字</string>

    <!-- Temp-use lockout (post-3rd, 5min cooldown) -->
    <string name="temp_use_locked_title">已封鎖 5 分鐘</string>
    <string name="temp_use_locked_body">為了保護您的資產，防詐器已暫時封鎖臨時轉帳。\n剩餘冷卻時間：%1$s</string>
    <string name="temp_use_locked_call">撥打 165 諮詢</string>

    <!-- Post-lockout 10-min watchful banner (主頁頂部橘色條) -->
    <string name="temp_use_watchful_banner_title">⚠️ 警示期 — 剩 %1$s</string>
    <string name="temp_use_watchful_banner_body">此期間若再達第三次臨時轉帳，將強制封鎖 1 小時。</string>

    <!-- 1-hour escalation ban (gate screen + main-screen overlay) -->
    <string name="temp_use_banned_title">⛔ 已強制封鎖轉帳功能 1 小時</string>
    <string name="temp_use_banned_body">防詐器轉帳相關功能已被暫時鎖定。\n您仍可使用防詐專區查看防詐資訊。\n\n剩餘封鎖時間：%1$s</string>

    <!-- Daily-add lockdown screen (畫面 10) -->
    <string name="daily_add_lock_title">⚠️ 偵測到異常新增行為</string>
    <string name="daily_add_lock_body">您今日已新增 3 筆轉帳帳號，這是常見的詐騙誘導模式。\n為了您的資產安全，新增功能已封鎖 24 小時。</string>
    <string name="daily_add_lock_call">立即撥打 165 防詐諮詢</string>
    <string name="daily_add_lock_return">返回防詐器</string>
    <string name="daily_add_lock_warn_2">提醒：您今日已達 3 筆新增上限，再新增 1 筆將觸發 24 小時封鎖。</string>
    <string name="daily_add_locked_remaining">新增功能仍在封鎖中，剩餘 %1$s</string>

