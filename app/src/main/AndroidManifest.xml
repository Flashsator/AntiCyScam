<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for fullscreen overlay warning ("請從防詐器進入") -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- a11y-OFF fallback: UsageStatsForegroundDetector polls the foreground app
         via UsageStatsManager when the AccessibilityService is not enabled.
         Special-access permission — granted only via the system "Usage access"
         settings page, never at runtime. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Battery-optimization whitelist request (Phase 3, Android 12 reliability fix).
         Without this, OEM doze can kill the AccessibilityService silently. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Required to enumerate installed apps for binding flow.
         Google Play requires justification at submission time. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Foreground service for keeping AccessibilityService alive on aggressive OEMs -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Boot-time service start (PRD § 8 heartbeat) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibrate for warning haptics -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Auto-detect end of call so we can offer to transcribe the OEM call recording.
         Runtime permission; if not granted the detector silently no-ops. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Read OEM call recording files via MediaStore.
         Android 13+ split READ_EXTERNAL_STORAGE → READ_MEDIA_*; declare both
         with maxSdkVersion on the legacy one so older devices still work. -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Network access for 防詐專區 article thumbnails (Coil loads imageUrl).
         If a tactic only has a bundled imageAsset, no network is touched.
         Also used by AppUpdateChecker to fetch app_version.json + the APK. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- In-app APK updater: lets us hand a downloaded update APK to the system
         package installer. The user still confirms "安裝不明應用程式" per OS policy. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Fallback intent filter visibility for sideload + Play Store policy.
         Even with QUERY_ALL_PACKAGES, declaring <queries> is a defensive fallback. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
    </queries>

    <application
        android:name=".AntiScamApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AntiCyScam"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.AntiCyScam">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Blocking warning activity (fullscreen, overlay-style, shown when bound
             app is launched without authorization). Configured for Phase 8. -->
        <activity
            android:name=".ui.warning.BlockingWarningActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:taskAffinity=""
            android:theme="@style/Theme.AntiCyScam.FullscreenWarning"
            android:turnScreenOn="true" />

        <!-- Temp-use 3-stage gate (PRD § 3.3) -->
        <activity
            android:name=".ui.tempuse.TempUseGateActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/Theme.AntiCyScam.FullscreenWarning" />

        <!-- Daily-add lockdown (PRD § 3.2 / 畫面 10) -->
        <activity
            android:name=".ui.lockdown.DailyAddLockActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/Theme.AntiCyScam.FullscreenWarning" />

        <!-- 防詐專區 top toolbar → 圖片辨識 / 文字辨識 / 語音辨識 host.
             Also registered as ACTION_SEND target so users can share suspicious
             content from LINE / FB / Chrome / screenshot apps directly into
             the scam-info recognition flow. -->
        <activity
            android:name=".ui.recognition.RecognitionActivity"
            android:exported="true"
            android:label="@string/share_recognition_label"
            android:theme="@style/Theme.AntiCyScam">
            <intent-filter android:label="@string/share_recognition_label">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter android:label="@string/share_recognition_label">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter android:label="@string/share_recognition_label">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
        </activity>

        <!-- Accessibility service registered for Phase 7. -->
        <service
            android:name=".service.AntiScamAccessibilityService"
            android:exported="false"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Foreground service that keeps the AccessibilityService alive
             on aggressive OEMs (PRD § 8). -->
        <service
            android:name=".service.AntiScamForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="anti_fraud_watchdog" />
        </service>

        <!-- Boot / package-replaced receiver re-arms the foreground service -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Android 14+ allows users to swipe FGS notifications away. This receiver
             is the deleteIntent target — when fired, it immediately revives the
             foreground service so the notification reappears instantly. -->
        <receiver
            android:name=".service.NotificationRevivalReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.anticyscam.app.NOTIFICATION_DISMISSED" />
            </intent-filter>
        </receiver>

        <!-- Exposes the downloaded update APK (cacheDir/update/) to the system
             package installer as a content:// URI. Paths in @xml/file_paths. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Device admin scaffold: optional, opt-in only.
             Activation goes through system settings; declared here so it is
             discoverable. -->
        <receiver
            android:name=".service.AntiScamDeviceAdminReceiver"
            android:exported="true"
            android:label="@string/device_admin_label"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
